<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>廉生 受験学習カレンダー 2026-2027</title>
<style>
  :root{
    --bg:#f5f7fb; --card:#fff; --ink:#182033; --muted:#6f7890;
    --line:#dfe4ef; --accent:#3857d6; --accent-soft:#eaf0ff;
    --rest:#f3f4f7; --exam:#ffe7e5; --deadline:#fff2cc;
    --counsel:#e7f7ef; --done:#e9f7e9; --shadow:0 8px 30px rgba(31,44,78,.08);
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Hiragino Sans","Yu Gothic",Meiryo,sans-serif}
  header{position:sticky;top:0;z-index:20;background:rgba(245,247,251,.94);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
  .topbar{max-width:1500px;margin:auto;padding:14px 18px;display:flex;gap:14px;align-items:center;justify-content:space-between}
  h1{font-size:20px;margin:0}
  .sub{font-size:12px;color:var(--muted);margin-top:3px;display:flex;gap:8px;align-items:center;flex-wrap:wrap}
  .sync-pill{font-size:10px;padding:2px 8px;border-radius:999px;background:var(--accent-soft);color:var(--accent);font-weight:600}
  .sync-pill.saving{background:#fff2cc;color:#7d5d05}
  .sync-pill.err{background:#ffe7e5;color:#a7332b}
  .setup-banner{max-width:1500px;margin:10px auto 0;padding:12px 18px;background:#fff2cc;border:1px solid #e7d38c;border-radius:12px;font-size:13px;line-height:1.6}
  .setup-banner code{background:#fffaf0;padding:1px 5px;border-radius:5px}
  button,select,input{font:inherit}
  button{border:1px solid var(--line);background:#fff;border-radius:10px;padding:9px 12px;cursor:pointer}
  button:hover{border-color:#aeb8d5}
  button:disabled{opacity:.5;cursor:not-allowed}
  .layout{max-width:1500px;margin:auto;padding:18px;display:grid;grid-template-columns:290px minmax(0,1fr);gap:18px}
  .panel{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow)}
  .sidebar{padding:16px;align-self:start;position:sticky;top:86px}
  .sidebar h2{font-size:15px;margin:2px 0 12px}
  .stat{display:grid;grid-template-columns:1fr auto;gap:8px;padding:8px 0;border-bottom:1px solid var(--line);font-size:13px}
  .progress{height:10px;background:#edf0f6;border-radius:99px;overflow:hidden;margin:11px 0 16px}
  .progress > div{height:100%;background:var(--accent);width:0;transition:width .3s ease}
  .settings label{display:block;font-size:12px;color:var(--muted);margin:10px 0 4px}
  .settings select,.settings input{width:100%;border:1px solid var(--line);border-radius:9px;padding:8px;background:white}
  .legend{display:grid;gap:7px;margin-top:16px;font-size:12px}
  .legend div{display:flex;align-items:center;gap:8px}
  .dot{width:11px;height:11px;border-radius:3px;border:1px solid rgba(0,0,0,.08)}
  .calendar-panel{padding:14px;min-width:0;position:relative}
  .cal-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px}
  .cal-head h2{margin:0;font-size:22px}
  .nav{display:flex;gap:8px}
  .weekdays,.calendar{display:grid;grid-template-columns:repeat(7,minmax(118px,1fr))}
  .weekdays div{font-size:12px;color:var(--muted);text-align:center;padding:8px}
  .weekdays div:first-child{color:#c33}
  .weekdays div:last-child{color:#3563b8}
  .day{min-height:168px;border-top:1px solid var(--line);border-left:1px solid var(--line);padding:8px;background:#fff;overflow:hidden}
  .day:nth-child(7n){border-right:1px solid var(--line)}
  .calendar .day:nth-last-child(-n+7){border-bottom:1px solid var(--line)}
  .day.other{background:#fafbfe;color:#adb3c2}
  .day.rest{background:var(--rest)}
  .day.today{outline:2px solid var(--accent);outline-offset:-2px}
  .date-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
  .date-num{font-weight:700;font-size:13px}
  .badge{font-size:10px;border-radius:999px;padding:2px 6px;background:#eef1f7;color:#586178}
  .badge.exam{background:var(--exam);color:#a7332b}
  .badge.deadline{background:var(--deadline);color:#7d5d05}
  .badge.counsel{background:var(--counsel);color:#227348}
  .task{display:flex;gap:6px;align-items:flex-start;font-size:11px;line-height:1.35;margin:5px 0;padding:4px 5px;border-radius:7px}
  .task:hover{background:#f7f9fd}
  .task input{margin:1px 0 0;flex:0 0 auto}
  .task.done span{text-decoration:line-through;color:#99a0b0}
  .task.event{font-weight:700;background:var(--exam)}
  .task.deadline{font-weight:700;background:var(--deadline)}
  .task.counsel{background:var(--counsel)}
  .rest-note{font-size:12px;color:#7a8190;text-align:center;margin-top:44px}
  .more{font-size:10px;color:var(--accent);cursor:pointer;margin-top:5px}
  dialog{border:none;border-radius:16px;box-shadow:0 24px 80px rgba(0,0,0,.22);width:min(720px,92vw);max-height:84vh;padding:0}
  dialog::backdrop{background:rgba(20,28,50,.35)}
  .modal-head{padding:16px 18px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
  .modal-body{padding:16px 18px;overflow:auto;max-height:68vh}
  .modal-body .task{font-size:14px;padding:8px}
  .note{font-size:12px;color:var(--muted);line-height:1.55}
  .load-overlay{position:absolute;inset:0;background:rgba(255,255,255,.85);display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--muted);border-radius:16px;z-index:5}
  @media(max-width:900px){
    .layout{grid-template-columns:1fr;padding:10px}
    .sidebar{position:static}
    .weekdays,.calendar{grid-template-columns:repeat(7,minmax(92px,1fr));min-width:720px}
    .calendar-panel{overflow:auto}
    .day{min-height:150px}
  }
</style>
</head>
<body>
<header>
  <div class="topbar">
    <div>
      <h1>廉生 受験学習カレンダー</h1>
      <div class="sub">
        <span>2026年7月22日〜2027年1月9日｜日曜は完全休息｜週1回・1時間の進路相談</span>
        <span id="syncPill" class="sync-pill">読み込み中…</span>
      </div>
    </div>
    <div>
      <button id="todayBtn">今日へ</button>
      <button id="resetBtn">進捗をリセット</button>
    </div>
  </div>
</header>

<div id="setupBanner" class="setup-banner" style="display:none">
  まだバックエンドの設定が済んでいません。<code>index.html</code> 内の
  <code>GAS_URL</code> をデプロイして得た <code>.../exec</code> のURLに、
  <code>SECRET_KEY</code> を自分だけの合言葉に書き換えてください（<code>Code.gs</code>側の
  <code>SECRET_KEY</code> と同じ文字列にすること）。それまでは保存できません。
</div>

<main class="layout">
  <aside class="panel sidebar">
    <h2>進捗</h2>
    <div class="stat"><span>完了タスク</span><strong id="doneCount">0</strong></div>
    <div class="stat"><span>対象タスク</span><strong id="totalCount">0</strong></div>
    <div class="stat"><span>達成率</span><strong id="rate">0%</strong></div>
    <div class="progress"><div id="progressBar"></div></div>

    <h2>週1回の進路相談（必須）</h2>
    <div class="settings">
      <label for="counselDay">曜日</label>
      <select id="counselDay">
        <option value="1">月曜日</option><option value="2">火曜日</option>
        <option value="3" selected>水曜日</option><option value="4">木曜日</option>
        <option value="5">金曜日</option><option value="6">土曜日</option>
      </select>
      <label for="counselTime">開始時刻</label>
      <input id="counselTime" type="time" value="19:00">
      <p class="note">変更すると、全期間の相談予約タスクに反映されます。日曜日は選べません。この設定と進捗はどの端末・どのブラウザから開いても共通で表示されます。</p>
    </div>

    <h2>表示の意味</h2>
    <div class="legend">
      <div><span class="dot" style="background:var(--exam)"></span>試験・合格発表</div>
      <div><span class="dot" style="background:var(--deadline)"></span>出願期間・締切</div>
      <div><span class="dot" style="background:var(--counsel)"></span>進路相談 1時間</div>
      <div><span class="dot" style="background:var(--rest)"></span>日曜・完全休息</div>
    </div>
  </aside>

  <section class="panel calendar-panel">
    <div id="loadOverlay" class="load-overlay">データを読み込み中…</div>
    <div class="cal-head">
      <div class="nav"><button id="prevBtn">← 前月</button><button id="nextBtn">次月 →</button></div>
      <h2 id="monthTitle"></h2>
      <button id="jumpStartBtn">計画開始へ</button>
    </div>
    <div class="weekdays"><div>日</div><div>月</div><div>火</div><div>水</div><div>木</div><div>金</div><div>土</div></div>
    <div id="calendar" class="calendar"></div>
  </section>
</main>

<dialog id="dayDialog">
  <div class="modal-head"><strong id="dialogTitle"></strong><button id="closeDialog">閉じる</button></div>
  <div id="dialogBody" class="modal-body"></div>
</dialog>

<script>
/* =====================================================================
   バックエンドURL（ここだけ書き換えれば動きます）
   Google Apps Script（Code.gs）を「ウェブアプリ」としてデプロイした際に
   発行される、".../exec" で終わるURLを貼り付けてください。
   ===================================================================== */
const GAS_URL = "https://script.google.com/macros/s/AKfycbxoWR30YK22EBaIjLscjXmvEY5NT-fScivgNl0hrLUk2TGa5CIqbttvo-7b7ytIJCiMxw/exec";

/* Code.gs の SECRET_KEY と必ず同じ文字列にしてください。 */
const SECRET_KEY = "renseihappy";

const START = new Date(2026,6,22);
const END   = new Date(2027,0,9);
const DAY = 86400000;

let currentMonth = new Date(2026,6,1);
let state = {};                          // task completion, keyed by "date|text"
let settings = { day: 3, time: "19:00" }; // weekly counseling settings

const fixedEvents = {
  "2026-09-15":[["deadline","早稲田 出願開始（Web・書類郵送）"]],
  "2026-09-28":[["deadline","早稲田 出願最終日"]],
  "2026-10-06":[["deadline","法政 出願開始"]],
  "2026-10-16":[["deadline","法政 出願最終日"]],
  "2026-10-23":[["event","早稲田 第一次合格発表"]],
  "2026-11-14":[["event","早稲田 第二次試験（小論文90分・面接）"]],
  "2026-11-20":[["event","早稲田 最終合格発表"],["event","法政 第一次合格発表"]],
  "2026-11-29":[["event","法政 第二次試験（小論文60分・面接）"]],
  "2026-12-04":[["deadline","東海 出願開始"]],
  "2026-12-08":[["event","法政 最終合格発表"]],
  "2026-12-14":[["deadline","東海 出願最終日"]],
  "2026-12-24":[["event","東海 試験（適性面接・自己PR5分・口述）"]],
  "2027-01-09":[["event","東海 合格発表"]]
};

function ymd(d){ return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`; }
function inRange(d){ return d >= START && d <= END; }
function add(arr, type, text){ arr.push({type,text}); }

function phaseTasks(d){
  const tasks=[], key=ymd(d), dow=d.getDay();
  if(!inRange(d) || dow===0) return tasks;

  const w1 = new Date(2026,8,28), h1 = new Date(2026,10,14), h2 = new Date(2026,10,29), t1 = new Date(2026,11,24);

  if([1,3,5].includes(dow)) add(tasks,"study","ニュース1本（スポーツ・健康）を読み、要点＋自分の意見を120字");
  if([2,4].includes(dow)) add(tasks,"study","面接想定質問を2問、声に出して回答");
  if(dow===6) add(tasks,"study","週の振り返り：完了状況と翌週の重点を10分で整理");

  if(d <= w1){
    if(dow===1) add(tasks,"study","早稲田：志望理由・競技歴・将来目標をブラッシュアップ");
    if(dow===2) add(tasks,"study","小論文：構成練習（主張→根拠→具体例→結論）");
    if(dow===3) add(tasks,"study","法政：志望理由書・競技資料の整理");
    if(dow===4) add(tasks,"study","早稲田面接：志望理由／スポーツ経験／大学で学びたいこと");
    if(dow===5) add(tasks,"study","小論文：スポーツ・社会テーマ 1題（60〜90分）");
    if(dow===6) add(tasks,"study","出願書類チェック・不足資料の確認");
  }
  else if(d < h1){
    if(dow===1) add(tasks,"study","早稲田小論文：資料読解＋論理展開 1題");
    if(dow===2) add(tasks,"study","法政面接：なぜ法政か／入学後に学びたいこと");
    if(dow===3) add(tasks,"study","早稲田面接：模擬面接20分＋改善点記録");
    if(dow===4) add(tasks,"study","法政小論文：スポーツ・健康分野 1題");
    if(dow===5) add(tasks,"study","早稲田：小論文の口頭説明＋深掘り質問");
    if(dow===6) add(tasks,"study","早稲田・法政の弱点補強／書類最終確認");
  }
  else if(d < h2){
    if(dow===1) add(tasks,"study","法政小論文：60分で1題、見直し10分");
    if(dow===2) add(tasks,"study","法政面接：志望理由・競技継続・将来目標");
    if(dow===3) add(tasks,"study","模擬面接30分＋回答の言い換え練習");
    if(dow===4) add(tasks,"study","スポーツ・健康ニュースから口頭意見練習");
    if(dow===5) add(tasks,"study","法政小論文：過去テーマ想定演習");
    if(dow===6) add(tasks,"study","本番セット練習（小論文60分＋面接）");
  }
  else if(d < t1){
    if(dow===1) add(tasks,"study","東海：自己PR5分の原稿・スライドなしで練習");
    if(dow===2) add(tasks,"study","健康基礎：運動・栄養・睡眠・メンタルヘルス");
    if(dow===3) add(tasks,"study","東海面接：志望理由・高校生活・将来像");
    if(dow===4) add(tasks,"study","健康課題：健康寿命／高齢化／生活習慣病");
    if(dow===5) add(tasks,"study","口述練習：想定質問4問を1分ずつで回答");
    if(dow===6) add(tasks,"study","自己PR通し練習＋録音確認＋改善");
  } else {
    if(dow!==0) add(tasks,"study","結果確認・提出物整理／次の手続き確認");
  }

  const reminders = [
    [new Date(2026,8,8),"早稲田出願書類を完成版にする"],
    [new Date(2026,8,21),"早稲田Web出願・郵送状況を確認"],
    [new Date(2026,9,2),"法政出願書類を完成版にする"],
    [new Date(2026,10,7),"早稲田 本番1週間前：睡眠・持ち物・会場確認"],
    [new Date(2026,10,22),"法政 本番1週間前：時間配分と持ち物確認"],
    [new Date(2026,11,2),"東海出願書類を完成版にする"],
    [new Date(2026,11,17),"東海 本番1週間前：自己PR最終調整"]
  ];
  for(const [date,text] of reminders) if(key===ymd(date)) add(tasks,"deadline",text);

  if(dow===Number(settings.day)){
    add(tasks,"counsel",`進路相談（必須・1時間） ${settings.time}〜`);
  }

  (fixedEvents[key]||[]).forEach(([type,text])=>add(tasks,type,text));
  return tasks;
}

function taskId(date,text){ return `${date}|${text}`; }

// ---------- Sync with the Apps Script backend (independent of any device) ----------

function setSyncPill(mode){
  const el = document.getElementById("syncPill");
  if(mode==="loading"){ el.textContent="読み込み中…"; el.className="sync-pill"; }
  else if(mode==="saving"){ el.textContent="保存中…"; el.className="sync-pill saving"; }
  else if(mode==="saved"){ el.textContent="保存済み・同期中"; el.className="sync-pill"; }
  else if(mode==="error"){ el.textContent="保存に失敗しました"; el.className="sync-pill err"; }
}

function backendConfigured(){
  return GAS_URL && !GAS_URL.startsWith("REPLACE_WITH");
}

async function loadData(){
  setSyncPill("loading");
  if(!backendConfigured()){
    document.getElementById("setupBanner").style.display = "block";
    setSyncPill("error");
    return;
  }
  try{
    const url = GAS_URL + "?key=" + encodeURIComponent(SECRET_KEY);
    const res = await fetch(url, { method: "GET" });
    if(!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if(data.ok === false) throw new Error(data.error || "unauthorized");
    state = data.state || {};
    settings = Object.assign({day:3,time:"19:00"}, data.settings || {});
    setSyncPill("saved");
  }catch(e){
    console.error("Load failed", e);
    setSyncPill("error");
  }
}

async function saveData(){
  if(!backendConfigured()){
    document.getElementById("setupBanner").style.display = "block";
    setSyncPill("error");
    return;
  }
  setSyncPill("saving");
  try{
    // text/plain avoids a CORS preflight request against the Apps Script endpoint.
    const res = await fetch(GAS_URL, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" },
      body: JSON.stringify({ key: SECRET_KEY, state, settings })
    });
    if(!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if(data.ok === false) throw new Error(data.error || "unauthorized");
    setSyncPill("saved");
  }catch(e){
    console.error("Save failed", e);
    setSyncPill("error");
  }
}

// ---------- Rendering ----------

function render(){
  document.getElementById("monthTitle").textContent = `${currentMonth.getFullYear()}年 ${currentMonth.getMonth()+1}月`;
  const cal=document.getElementById("calendar"); cal.innerHTML="";
  const first=new Date(currentMonth.getFullYear(),currentMonth.getMonth(),1);
  const gridStart=new Date(first); gridStart.setDate(1-first.getDay());
  for(let i=0;i<42;i++){
    const d=new Date(gridStart); d.setDate(gridStart.getDate()+i);
    const key=ymd(d), tasks=phaseTasks(d);
    const cell=document.createElement("div");
    cell.className="day"+(d.getMonth()!==currentMonth.getMonth()?" other":"")+(d.getDay()===0?" rest":"")+(key===ymd(new Date())?" today":"");
    const badges=[];
    if(fixedEvents[key]?.some(x=>x[0]==="event")) badges.push('<span class="badge exam">重要日</span>');
    else if(fixedEvents[key]?.some(x=>x[0]==="deadline")) badges.push('<span class="badge deadline">出願</span>');
    else if(d.getDay()===Number(settings.day) && inRange(d)) badges.push('<span class="badge counsel">相談</span>');
    cell.innerHTML=`<div class="date-row"><span class="date-num">${d.getDate()}</span><span>${badges.join("")}</span></div>`;
    if(d.getDay()===0 && inRange(d)){
      cell.innerHTML += '<div class="rest-note">完全休息日<br>勉強タスクなし</div>';
    } else {
      const visible=tasks.slice(0,4);
      visible.forEach(t=>cell.appendChild(taskNode(key,t)));
      if(tasks.length>4){
        const more=document.createElement("div"); more.className="more"; more.textContent=`＋${tasks.length-4}件を表示`;
        more.onclick=()=>openDay(d,tasks); cell.appendChild(more);
      }
    }
    if(tasks.length && tasks.length<=4) cell.onclick=(e)=>{ if(e.target.tagName!=="INPUT") openDay(d,tasks); };
    cal.appendChild(cell);
  }
  updateStats();
}

function taskNode(date,t){
  const id=taskId(date,t.text), wrap=document.createElement("label");
  wrap.className=`task ${t.type} ${state[id]?"done":""}`;
  const cb=document.createElement("input"); cb.type="checkbox"; cb.checked=!!state[id];
  const span=document.createElement("span"); span.textContent=t.text;
  cb.onchange=(e)=>{
    state[id]=e.target.checked;
    wrap.classList.toggle("done",e.target.checked);
    updateStats();
    saveData();
    e.stopPropagation();
  };
  wrap.append(cb,span); return wrap;
}

function openDay(d,tasks){
  document.getElementById("dialogTitle").textContent=`${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日（${"日月火水木金土"[d.getDay()]}）`;
  const body=document.getElementById("dialogBody"); body.innerHTML="";
  if(d.getDay()===0){ body.innerHTML='<p>完全休息日です。学習・相談の予定は入れません。</p>'; }
  else tasks.forEach(t=>body.appendChild(taskNode(ymd(d),t)));
  document.getElementById("dayDialog").showModal();
}

function updateStats(){
  let total=0,done=0;
  for(let d=new Date(START); d<=END; d=new Date(d.getTime()+DAY)){
    for(const t of phaseTasks(d)){ total++; if(state[taskId(ymd(d),t.text)]) done++; }
  }
  const rate=total?Math.round(done/total*100):0;
  doneCount.textContent=done; totalCount.textContent=total; document.getElementById("rate").textContent=rate+"%";
  document.getElementById("progressBar").style.width=rate+"%";
}

document.getElementById("prevBtn").onclick=()=>{ currentMonth=new Date(currentMonth.getFullYear(),currentMonth.getMonth()-1,1); render(); };
document.getElementById("nextBtn").onclick=()=>{ currentMonth=new Date(currentMonth.getFullYear(),currentMonth.getMonth()+1,1); render(); };
document.getElementById("todayBtn").onclick=()=>{ const t=new Date(); currentMonth=inRange(t)?new Date(t.getFullYear(),t.getMonth(),1):new Date(2026,6,1); render(); };
document.getElementById("jumpStartBtn").onclick=()=>{ currentMonth=new Date(2026,6,1); render(); };
document.getElementById("closeDialog").onclick=()=>document.getElementById("dayDialog").close();

document.getElementById("resetBtn").onclick=async ()=>{
  if(!confirm("すべての完了チェックをリセットしますか？（他の端末の表示にも反映されます）")) return;
  document.getElementById("resetBtn").disabled = true;
  state={};
  await saveData();
  document.getElementById("resetBtn").disabled = false;
  render();
};

document.getElementById("counselDay").onchange=async ()=>{
  settings.day = Number(document.getElementById("counselDay").value);
  await saveData();
  render();
};
document.getElementById("counselTime").onchange=async ()=>{
  settings.time = document.getElementById("counselTime").value;
  await saveData();
  render();
};

(async function init(){
  await loadData();
  document.getElementById("counselDay").value = settings.day;
  document.getElementById("counselTime").value = settings.time;
  document.getElementById("loadOverlay").remove();
  render();
})();
</script>
